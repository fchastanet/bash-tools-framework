        fi

        if ((options_parse_optionParsedCountOptionHideSelector >= 1 )); then
          Log::displayError "Command ${SCRIPT_NAME} - Option ${options_parse_arg} - Maximum number of option occurrences reached(1)"
          return 1
        fi
        ((++options_parse_optionParsedCountOptionHideSelector))
        # shellcheck disable=SC2034
        optionHideSelector="$1"
        ;;

      # Option 27/27
      # optionFileFilter alts --file-filter
      # type: String min 0 max 1
      --file-filter)
        shift
        if (($# == 0)); then
          Log::displayError "Command ${SCRIPT_NAME} - Option ${options_parse_arg} - a value needs to be specified"
          return 1
        fi

        if ((options_parse_optionParsedCountOptionFileFilter >= 1 )); then
          Log::displayError "Command ${SCRIPT_NAME} - Option ${options_parse_arg} - Maximum number of option occurrences reached(1)"
