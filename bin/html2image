  Array::wrap2 ' ' 76 4 "    " "Quiet mode, doesn't display any output."
  echo

  echo
  echo -e "${__HELP_TITLE_COLOR}OPTIONS:${__RESET_COLOR}"
  echo -e "  ${__HELP_OPTION_COLOR}--ci${__HELP_NORMAL} {single}"
  Array::wrap2 ' ' 76 4 "    " "Activate continuous integration mode (tmp folder not shared with host)" ""
  echo


  echo -e "  ${__HELP_OPTION_COLOR}--format${__HELP_NORMAL}, ${__HELP_OPTION_COLOR}-f <Format>${__HELP_NORMAL} {list} (optional)"
  Array::wrap2 ' ' 76 4 "    " "Output image format (default: webp if not provided)"
  echo

  echo "    Possible values: "
  Array::wrap2 ' ' 76 8 "      - ${__OPTION_COLOR}png:${__RESET_COLOR} PNG raster format"
  echo
  Array::wrap2 ' ' 76 8 "      - ${__OPTION_COLOR}jpg:${__RESET_COLOR} JPEG raster format"
  echo
  Array::wrap2 ' ' 76 8 "      - ${__OPTION_COLOR}jpeg:${__RESET_COLOR} JPEG raster format (alias)"
  echo
  Array::wrap2 ' ' 76 8 "      - ${__OPTION_COLOR}webp:${__RESET_COLOR} WebP format (recommended)"
  echo

  echo -e "  ${__HELP_OPTION_COLOR}--same-dir${__HELP_NORMAL} {single}"
  Array::wrap2 ' ' 76 4 "    " "Write output file in same directory as source file" "with the same base name (except extension)." "Incompatible with --output-dir and --output." ""
  echo


  echo -e "  ${__HELP_OPTION_COLOR}--output-dir${__HELP_NORMAL}, ${__HELP_OPTION_COLOR}-d <OutputDir>${__HELP_NORMAL} {single}"
  Array::wrap2 ' ' 76 4 "    " "Output directory for generated images (default: doc/images)." "Incompatible with --same-dir and --output." ""
  echo


  echo -e "  ${__HELP_OPTION_COLOR}--output${__HELP_NORMAL}, ${__HELP_OPTION_COLOR}-o <OutputFile>${__HELP_NORMAL} {single}"
  Array::wrap2 ' ' 76 4 "    " "Output file path. Required when using stdin input." "Incompatible with --same-dir and --output-dir." ""
  echo


  echo -e "  ${__HELP_OPTION_COLOR}--transform-cmd${__HELP_NORMAL}, ${__HELP_OPTION_COLOR}-t <TransformCmd>${__HELP_NORMAL} {single}"
  Array::wrap2 ' ' 76 4 "    " "Transform command to apply before generating image." "Use ${__HELP_OPTION_COLOR}%tempFile%${__RESET_COLOR} placeholder for temporary HTML output file." "Example: 'npx -y @markwhen/mw -o timeline -d ${__HELP_OPTION_COLOR}%tempFile%${__RESET_COLOR}'" ""
  echo


  echo -e "  ${__HELP_OPTION_COLOR}--viewport <Viewport>${__HELP_NORMAL} {single}"
  Array::wrap2 ' ' 76 4 "    " "Browser viewport size in WIDTHxHEIGHT format (e.g., 1920x1080)." "If not specified, the viewport is automatically sized to fit the page content." ""
  echo


  echo -e "  ${__HELP_OPTION_COLOR}--quality <Quality>${__HELP_NORMAL} {single}"
  Array::wrap2 ' ' 76 4 "    " "Image quality for JPEG/WEBP formats, 0-100 (default: 90)." ""
  echo


  Array::wrap2 ' ' 76 6 "    Default value: " "90"
  echo

  echo -e "  ${__HELP_OPTION_COLOR}--full-page${__HELP_NORMAL} {single}"
  Array::wrap2 ' ' 76 4 "    " "Capture full scrollable page height instead of viewport height." ""
  echo


  echo -e "  ${__HELP_OPTION_COLOR}--wait-for-render <Milliseconds>${__HELP_NORMAL} {single}"
  Array::wrap2 ' ' 76 4 "    " "Extra wait time in milliseconds after page load, for JS-rendered" "content such as SPAs or web components (default: 0)." "Example: --wait-for-render 2000" ""
  echo


  Array::wrap2 ' ' 76 6 "    Default value: " "0"
  echo

  echo -e "  ${__HELP_OPTION_COLOR}--wait-for-selector <Selector>${__HELP_NORMAL} {single}"
  Array::wrap2 ' ' 76 4 "    " "CSS selector to wait for before taking the screenshot." "Useful when the target element is rendered asynchronously." "Example: --wait-for-selector '#app'" ""
  echo


  echo -e "  ${__HELP_OPTION_COLOR}--inject-css <CssFile>${__HELP_NORMAL} {single}"
  Array::wrap2 ' ' 76 4 "    " "Path to a CSS file to inject into the page before screenshot." "Useful to override styles, hide elements, or apply custom theme." "Example: --inject-css custom.css" ""
  echo


  echo -e "  ${__HELP_OPTION_COLOR}--hide-selector <Selector>${__HELP_NORMAL} {single}"
  Array::wrap2 ' ' 76 4 "    " "CSS selector: the last matching element will be hidden before screenshot." "Useful to remove floating toolbars or overlays from the captured image." "Example: --hide-selector '#timeline > div.fixed'" ""
  echo


  echo -e "  ${__HELP_OPTION_COLOR}--file-filter <Regex>${__HELP_NORMAL} {single}"
  Array::wrap2 ' ' 76 4 "    " "Only process files matching the regular expression" "" "Example: ${__HELP_EXAMPLE}--file-filter '(\\.html|\\.htm)$'${__RESET_COLOR}" ""
  echo


  Array::wrap2 ' ' 76 6 "    Default value: " "(\.html|\.htm)$"
  echo
  # ------------------------------------------
  # longDescription section
  # ------------------------------------------
  echo
  echo
  echo -e "${__HELP_TITLE_COLOR}DESCRIPTION:${__RESET_COLOR}"
  declare -a html2imageCommandLongDescription=(
  "Converts HTML files to images (PNG, JPEG, WEBP) using Puppeteer."
  "Supports transform commands to generate HTML from other formats (e.g., Markwhen)."
  "Can process files from git repository, specified files, or stdin."
  ""
  "${__HELP_TITLE_COLOR}USAGE EXAMPLES:${__RESET_COLOR}"
  ""
  "# Convert HTML files from git repository"
  ""
  "${__HELP_EXAMPLE}"
  "html2image --format webp --same-dir"
  "${__RESET_COLOR}"
  ""
  "# Convert specific HTML file"
  ""
  "${__HELP_EXAMPLE}"
  "html2image --format webp --same-dir file.html"
  "${__RESET_COLOR}"
  ""
  "# Convert Markwhen file with transform"
  ""
  "${__HELP_EXAMPLE}"
  "html2image --format webp --same-dir \\"
  "  --transform-cmd 'npx -y @markwhen/mw -o timeline -d %tempFile%' \\"
  "  file.mwh"
  "${__RESET_COLOR}"
  ""
  "# Convert from stdin"
  ""
  "${__HELP_EXAMPLE}"
  "echo \"<html><body>Hello</body></html>\" | \\"
  "  ${__HELP_EXAMPLE}html2image --format png --output output.png"
  "${__RESET_COLOR}"
  ""
  "# Convert with custom css injection"
  ""
  "${__HELP_EXAMPLE}"
  "html2image --format webp --same-dir \\"
  "  --transform-cmd 'npx -y @markwhen/mw -o timeline -d %tempFile%' \\"
  "  --inject-css src/_binaries/html2image/tests/test-markwhen.css \\"
  "  src/_binaries/html2image/tests/test-markwhen.mwh"
  "${__RESET_COLOR}"
  ""
  "${__HELP_TITLE_COLOR}CHANGELOG:${__RESET_COLOR}"
  ""
  "Version 1.0 (2026-04-24):"
  ""
  "  - Initial version"
  "  - Support for PNG, JPEG, WEBP formats"
  "  - Transform command support with %tempFile% placeholder"
  "  - Stdin input support"
  "  - Configurable viewport size"
  "  - CI mode with extension checking"
  )
  Array::wrap2 ' ' 76 0 "${html2imageCommandLongDescription[@]}"
  echo
  # ------------------------------------------
  # version section
  # ------------------------------------------
  echo
  echo -n -e "${__HELP_TITLE_COLOR}VERSION: ${__RESET_COLOR}"
  echo "1.0"
  # ------------------------------------------
  # author section
  # ------------------------------------------
  echo
  echo -n -e "${__HELP_TITLE_COLOR}AUTHOR: ${__RESET_COLOR}"
  echo "[François Chastanet](https://github.com/fchastanet)"
  # ------------------------------------------
  # sourceFile section
  # ------------------------------------------
  echo
  echo -n -e "${__HELP_TITLE_COLOR}SOURCE FILE: ${__RESET_COLOR}"
  echo "https://github.com/fchastanet/bash-tools-framework/tree/master/src/_binaries/html2image/html2image-binary.yaml"
  # ------------------------------------------
  # license section
  # ------------------------------------------
  echo
  echo -n -e "${__HELP_TITLE_COLOR}LICENSE: ${__RESET_COLOR}"
  echo "MIT License"
  # ------------------------------------------
  # copyright section
  # ------------------------------------------
  Array::wrap2 ' ' 76 0 "$(copyrightCallback)"
}


