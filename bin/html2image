        optionInjectCss="$1"
        ;;

      # Option 26/27
      # optionHideSelector alts --hide-selector
      # type: String min 0 max 1
      --hide-selector)
        shift
        if (($# == 0)); then
          Log::displayError "Command ${SCRIPT_NAME} - Option ${options_parse_arg} - a value needs to be specified"
