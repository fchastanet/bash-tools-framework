Linux::requireTarCommand
Compiler::Embed::extractFileFromBase64 \
  "${PERSISTENT_TMPDIR:-/tmp}/428cff69f957489b9c4d6bc88f5bf8cff7f68d35f6927b58d1f5e1ef2b7406b8/krokiDockerCompose" \
  "LS0tCnNlcnZpY2VzOgogIGtyb2tpOgogICAgaW1hZ2U6IHl1enV0ZWNoL2tyb2tpCiAgICBjb250 \
